DATABASE_URL=postgresql://user:password@host:5432/database

# Optional fallback write key. Useful for script-based access.
ADMIN_ACTION_KEY=replace_with_strong_secret

# Recommended session auth for dashboard operators.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_password
ADMIN_SESSION_SECRET=replace_with_long_random_secret

# Optional live Paystack feed.
PAYSTACK_SECRET_KEY=replace_with_paystack_secret_key